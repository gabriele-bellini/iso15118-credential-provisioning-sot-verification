 *
 * Scenario (e2,s2)-variant-tpm-oracle:
 *)

(*
 * Adapting the NIST SP 800-56A $\text{C}(e2, s2)$ scheme and
 * TLS-style ephemeral Diffie-Hellman, our protocol guarantees
 * forward and post-compromise secrecy while specifically hardening
 * the session key exchange against signing-oracle threats targeted
 * at the Electric Vehicle (EV) side.
 * All key pairs shall be generated using the same domain parameters.
 * Party A (EV) and party B (eMSP) obtain each other’s static
 * public keys, which have been generated prior to the key-establishment
 * process.
 * Both parties generate ephemeral private/public key pairs and
 * exchange the ephemeral public keys. Using the static and ephemeral
 * keys, both parties generate a shared secret.
 * The secret keying material is derived from the shared secret.
 *
 * Conceptually, Party A and Party B have previously exchanged their
 * public keys and trust that the keys are authentic. In practice, they
 * exchange digital certificates containing their public keys, and each
 * party verifies the other's certificate to authenticate the public key.
  
    A -> B : {g*esk1}skA, { g*skA }sk_CERT  (esk1 fresh)
    B -> A : {g*esk2}skB, { g*skB }sk_CERT  (esk2 fresh)
    A and B compute the key as k = kdf((g*esk1)*esk2 || (g*skA)*esk2) = kdf((g*esk2)*esk1 || (g*esk2)*skA))
    B -> A : { communication }k

 * NOTE: A represent EV, B represent eMSP/CPS, communication represent
 * the secret contract key exchanged in the certificate install.
 * In the following code the static public keys authenticity is
 * enforced without explicitly signing them.
 *)

 (*
 * NOTE: with deterministic enc and no decryption oracle on an honest key,
 * strong secrecy coincides with reachability secrecy here. The added value is
 * certifying no partial leak, not merely non-extraction. Equivalence mode
 * over 5 phases + the DH equation can need `set` tuning and may report false
 * attacks.
 *)
free c: channel.

type group.
type scalar.
type key.


(* Shared key encryption *)

fun enc(bitstring, key): bitstring.
reduc forall x: bitstring, y: key; dec(enc(x,y),y) = x.

(* Key derivation function *)
fun kdf(group, group): key.

(* Diffie-Hellman *)

const g: group.
fun dh_oper(group, scalar): group.
equation forall x: scalar, y: scalar; dh_oper(dh_oper(g, x), y) = dh_oper(dh_oper(g, y), x).

(* Signatures *)
fun sign(group, scalar): bitstring.
reduc forall m: group, k: scalar; getmess(sign(m,k)) = m.
reduc forall m: group, k: scalar; checksign(sign(m,k), dh_oper(g, k)) = m.


free future_communications_fromCompromisedSkOwner: bitstring [private].
free future_communications_toCompromisedSkOwner: bitstring [private].
free communications_betweenCompromisedParties: bitstring [private].
free communications_betweenUncompromisedParties: bitstring [private].
free communications_afterFullKeyRenewal: bitstring [private].
free attacker_message: bitstring.

(* Test protocol termination *)
event messageReceived(bitstring).
(* These 5 event can be use to validate the model correct implementation *)
(* query event(messageReceived(communications_betweenUncompromisedParties)). *)
(* query event(messageReceived(future_communications_fromCompromisedSkOwner)). *)
(* query event(messageReceived(future_communications_toCompromisedSkOwner)). *)
(* query event(messageReceived(communications_betweenCompromisedParties)). *)
(* query event(messageReceived(communications_afterFullKeyRenewal)). *)

(* This, when proved reachable, demonstrate an impersonation attack *)
query event(messageReceived(attacker_message)).

(* Test whether communications are secret *)
query attacker(communications_betweenUncompromisedParties).
query attacker(future_communications_fromCompromisedSkOwner).
query attacker(future_communications_toCompromisedSkOwner).
query attacker(communications_betweenCompromisedParties).
query attacker(communications_afterFullKeyRenewal).


(* EV - we keep generic naming as the protocol is generic *)
let p0(skA: scalar, pkB: group) =
    new esk0: scalar;
    out(c,sign(dh_oper(g, esk0),skA));
    in(c, m1: bitstring);
    let epk1 = checksign(m1, pkB) in
(*     if epk1 <> pkB && epk1 <> dh_oper(g,skA) && epk1 <> g then *)
    let z0 = dh_oper(epk1, esk0) in
    let z2 = dh_oper(epk1, skA) in
    let k = kdf(z0,z2) in
    in (c,m: bitstring);
    let msg = dec(m,k) in
    event messageReceived(msg);
    0.
  

(* eMSP *)
let p1(skB: scalar, pkA: group, message: bitstring) =
    in(c,m: bitstring);
    let epk0 = checksign(m,pkA) in
(*     if epk0 <> pkA && epk0 <> dh_oper(g,skB) && epk0 <> g then *)
    new esk1: scalar;
    let z0 = dh_oper(epk0, esk1) in
    let z2 = dh_oper(pkA, esk1) in
    let k = kdf(z0,z2) in
    out(c, sign(dh_oper(g, esk1), skB));
    out(c, enc(message,k));
    0.

let tpm_oracle__dh_oper(sk: scalar) = in(c, x: group); out(c, dh_oper(x, sk)).

process
  new skA: scalar;
  let pkA = dh_oper(g, skA) in
  out(c, pkA);
  new skB: scalar;
  let pkB = dh_oper(g, skB) in
  out(c, pkB);
  out(c, attacker_message);
  (
    (*
     * Phase 0: before key leakage, sessions encrypt the payload.
     * These messages must remain indistinguishable after the later
     * leakage / oracle-abuse of the keys (forward secrecy).
     *)
    ( (!p0(skA, pkB)) | (!p1(skB, pkA, communications_betweenUncompromisedParties)) )
    |
    (*
     * Phase 1/2: skA is oracle-abused.
     * The sender's private signing key is used by the attacker as
     * an oracle over an attacker-chosen ephemeral (skA itself is never
     * revealed), but the sender is still able to communicate
     * with an uncompromised party.
     *)
    phase 1;
    ( !tpm_oracle__dh_oper(skA) ) |
    phase 2; (* Here the oracle is no longer available. Cannot be used interactively during the attack but only before it. *)
    ( (!p0(skA, pkB)) | (!p1(skB, pkA, future_communications_fromCompromisedSkOwner)) )
    |
    (*
     * Phase 3/4: also skB is oracle-abused.
     * Both signing keys have been used as oracles.
     *)
    phase 3;
    ( !tpm_oracle__dh_oper(skB) ) |
    phase 4; (* Here the oracle is no longer available. Cannot be used interactively during the attack but only before it. *)
    ( (!p0(skA, pkB)) | (!p1(skB, pkA, communications_betweenCompromisedParties)) )
    |
    (*
     * Phase 5: only skB remains oracle-abused;
     * skA has already been renewed to a fresh key.
     *)
    phase 5;
    new nwskA: scalar;
    let nwpkA = dh_oper(g, nwskA) in
    out(c, nwpkA);
    ( (!p0(nwskA, pkB)) | (!p1(skB, nwpkA, future_communications_toCompromisedSkOwner)) )
    |
    (*
     * Phase 6: FULL HEAL.
     * Both skA and skB are renewed to fresh, never-oracled keys.
     *
     * Backward secrecy / post-compromise security: once every compromised
     * signing key has been renewed, do future sessions regain full, strong
     * secrecy? The attacker still retains everything it learned in
     * Phases 1-3 (the oracled signatures over g^esk0 and g^esk1 and dh_oper under
     * the old keys), but those cannot help it impersonate, nor
     * distinguish traffic between, the holders of the fresh keys.
     *)
    phase 6;
    new healskA: scalar;
    let healpkA = dh_oper(g, healskA) in
    out(c, healpkA);
    new healskB: scalar;
    let healpkB = dh_oper(g, healskB) in
    out(c, healpkB);
    ( (!p0(healskA, healpkB)) | (!p1(healskB, healpkA, communications_afterFullKeyRenewal)) )
  )


(*
--------------------------------------------------------------
Verification summary:

(* Test protocol termination and correct implementation (The protocol is correctly modeled) *)
Query not event(messageReceived(communications_betweenUncompromisedParties[])) is false.
Query not event(messageReceived(future_communications_fromCompromisedSkOwner[])) is false.
Query not event(messageReceived(communications_betweenCompromisedParties[])) is false.

(* Query about impersonation (the attacker is NOT able to impersonate the legitimate sender) *)
Query not event(messageReceived(attacker_message[])) is true.

(* Query about confidentiality *)
Query not attacker_bitstring_p4(communications_betweenUncompromisedParties[]) is true.
Query not attacker_bitstring_p4(future_communications_fromCompromisedSkOwner[]) is true.
Query not attacker_bitstring_p4(future_communications_toCompromisedSkOwner[]) is true.


